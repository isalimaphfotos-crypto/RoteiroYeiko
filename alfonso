<script>
  function toggleScript(btn) {
    const full = btn.nextElementSibling;
    const isOpen = full.classList.contains('open');
    full.classList.toggle('open');
    btn.textContent = isOpen ? 'Ver roteiro completo ↓' : 'Ocultar roteiro ↑';
  }

  function filterCards(btn, category) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.card').forEach(card => {
      if (category === 'all') {
        card.classList.remove('hidden');
      } else {
        const cats = card.dataset.category || '';
        card.classList.toggle('hidden', !cats.includes(category));
      }
    });
  }
</script>
